# Supabase public client config.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Fallback for older Supabase/Vercel integrations that still expose an anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service key. Never expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle and server-side jobs.
DATABASE_URL=

# Optional direct connection string for migrations if your provider exposes one.
DIRECT_DATABASE_URL=

# External announcement feed refresh interval. Minimum is 30 seconds.
ANNOUNCEMENT_REFRESH_SECONDS=300

# Minimum score for external notices to appear in the admin program lead queue.
PROGRAM_LEAD_MIN_SCORE=2

# Optional comma-separated source IDs to disable from the default registry.
DISABLED_ANNOUNCEMENT_SOURCE_IDS=

# Optional JSON list of external RSS sources. When this is set, it replaces the
# default registry in src/lib/announcement-sources.ts.
# Keep sources to public/partner-approved feeds instead of scraping HTML pages.
EXTERNAL_ANNOUNCEMENT_SOURCES=[{"id":"mcst-notice","name":"MCST notice RSS","type":"rss","url":"http://www.mcst.go.kr/common/rss/notice.jsp","keywords":["관광","여행","지원","공모","모집","체류","워케이션"],"minimumKeywordMatches":0}]
