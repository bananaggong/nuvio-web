# Supabase public client config.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Fallback for older Supabase/Vercel integrations that still expose an anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Kakao JavaScript key for Kakao Maps SDK.
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=

# Server-only Supabase service key. Never expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle and server-side jobs.
DATABASE_URL=

# Optional direct connection string for migrations if your provider exposes one.
DIRECT_DATABASE_URL=

# External announcement feed refresh interval. Minimum is 1 hour.
# 43200 seconds = twice a day. Vercel Cron is configured as a daily backup.
ANNOUNCEMENT_REFRESH_SECONDS=43200

# Shared bearer token for cron routes such as /api/cron/refresh-announcements
# and /api/cron/process-notifications.
CRON_SECRET=

# Browser push notifications. Generate VAPID keys with:
# npx web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:support@nuvio.kr

# Manual message dispatch queue. By default, scheduled SMS messages are treated
# as work-phone manual dispatch tasks and are appended to this Google Sheet.
# Share the spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as an editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_MANUAL_MESSAGE_SPREADSHEET_ID=12giIcDfnxIvFyzCUlmntEIvRZe7nqTHkLXRJ8rYkrtc
GOOGLE_MANUAL_MESSAGE_SHEET_NAME=발송대기

# Keep disabled while messages are sent manually from a work phone.
# Set to true only when an actual SMS provider workflow is ready.
SMS_AUTO_DELIVERY_ENABLED=false

# Minimum score for external notices to appear in the admin program lead queue.
PROGRAM_LEAD_MIN_SCORE=2

# Meta/Facebook OAuth for host Instagram media imports.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
META_GRAPH_API_VERSION=v24.0

# Optional. When set, social access tokens are encrypted before DB storage.
SOCIAL_TOKEN_ENCRYPTION_KEY=

# Optional comma-separated source IDs to disable from the default registry.
DISABLED_ANNOUNCEMENT_SOURCE_IDS=

# Optional JSON list of external RSS sources. When this is set, it replaces the
# default registry in src/lib/announcement-sources.ts.
# Keep sources to public/partner-approved feeds instead of scraping HTML pages.
EXTERNAL_ANNOUNCEMENT_SOURCES=[{"id":"mcst-notice","name":"MCST notice RSS","type":"rss","url":"https://www.mcst.go.kr/common/rss/notice.jsp","keywords":["관광","여행","지원","공모","모집","체류","워케이션"],"minimumKeywordMatches":0}]
