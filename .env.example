# Supabase public client config.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Fallback for older Supabase/Vercel integrations that still expose an anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional. Show Naver login only after this Supabase custom provider exists.
# NEXT_PUBLIC_SUPABASE_NAVER_PROVIDER=custom:naver

# Kakao JavaScript key for Kakao Maps SDK.
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=

# Server-only Supabase service key. Never expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle and server-side jobs.
DATABASE_URL=

# Optional direct connection string for migrations if your provider exposes one.
DIRECT_DATABASE_URL=

# Public canonical site URL used in transactional email links.
NEXT_PUBLIC_SITE_URL=https://nuvio.kr

# Server-only release reset gate. Set to 1 only while production data is reset.
# When enabled, only /, /open, and /magazine/** remain available.
NUVIO_RELEASE_RESET_MODE=0

NUVIO_ENABLE_LOCAL_DEV_AUTH=0
NUVIO_LOCAL_DEV_EMAIL=local-dev@nuvio.invalid

# Launch feature flags. Keep reviews disabled until the public UX is ready.
NEXT_PUBLIC_ENABLE_REVIEWS=false

# Transactional email delivery for application status and review request emails.
# Production should use EMAIL_PROVIDER=resend or EMAIL_PROVIDER=webhook.
EMAIL_PROVIDER=
EMAIL_FROM="Nuvio <support@nuvio.kr>"
RESEND_API_KEY=
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_AUTH_HEADER=
EMAIL_WEBHOOK_AUTH_TOKEN=

# Shared bearer token for protected cron routes.
CRON_SECRET=

# Browser push notifications. Generate VAPID keys with:
# npx web-push generate-vapid-keys
# WEB_PUSH_DELIVERY_MODE=mock is accepted outside production for dry-run tests.
WEB_PUSH_DELIVERY_MODE=live
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:support@nuvio.kr

# Manual message dispatch queue. By default, scheduled SMS messages are treated
# as work-phone manual dispatch tasks and are appended to this Google Sheet.
# Share the spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as an editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_MANUAL_MESSAGE_SPREADSHEET_ID=12giIcDfnxIvFyzCUlmntEIvRZe7nqTHkLXRJ8rYkrtc
GOOGLE_MANUAL_MESSAGE_SHEET_NAME=발송대기
DISCORD_MANUAL_MESSAGE_WEBHOOK_URL=

# Keep disabled while messages are sent manually from a work phone.
# Set to true only when an actual SMS provider workflow is ready.
SMS_AUTO_DELIVERY_ENABLED=false
SMS_PROVIDER=mock
SMS_WEBHOOK_URL=
SMS_WEBHOOK_AUTH_HEADER=
SMS_WEBHOOK_AUTH_TOKEN=

# Meta/Facebook OAuth for host Instagram media imports.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
META_GRAPH_API_VERSION=v24.0

# Optional. When set, social access tokens are encrypted before DB storage.
SOCIAL_TOKEN_ENCRYPTION_KEY=
