{
  "name": "nuvio-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "audit:db-integrity": "node scripts/audit-db-integrity.mjs",
    "test:db-concurrency": "tsx --test tests/db-concurrency.test.ts",
    "verify:db-integrity": "node scripts/verify-db-integrity-artifacts.mjs && npm run test:db-concurrency",
    "test:async-ops": "tsx --test tests/async-operations.test.ts",
    "audit:async-ops": "node scripts/audit-async-operations.mjs",
    "audit:phone-quality": "node scripts/audit-member-phone-quality.mjs",
    "verify:ops-readiness": "node scripts/verify-ops-readiness-artifacts.mjs && npm run test:async-ops",
    "test:security": "node --test tests/browser-push-security.test.mjs tests/image-upload-security.test.mjs && tsx --test tests/api-access-matrix.test.ts tests/content-security.test.ts tests/korean-mobile-phone.test.ts tests/member-phone-boundaries.test.ts tests/naver-userinfo-route.test.ts tests/release-reset-proxy.test.ts tests/request-security.test.ts tests/security-boundaries.test.ts tests/server-error-diagnostics.test.ts tests/trusted-request-origin.test.ts",
    "pretest:security:e2e": "npm run build",
    "test:security:e2e": "playwright test --config=playwright.security.config.ts",
    "test:security:all": "npm run test:security && npm run test:security:e2e",
    "test:e2e:release": "playwright test --config=playwright.release.config.ts",
    "test:e2e:release:headed": "playwright test --config=playwright.release.config.ts --headed",
    "verify:host-program-flow": "node scripts/verify-host-program-flow.mjs",
    "verify:open-assets": "node scripts/verify-open-launch-assets.mjs",
    "verify:overflow": "node scripts/verify-route-overflow.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:db:reset": "supabase db reset",
    "supabase:db:push": "supabase db push"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tiptap/extension-image": "^3.24.0",
    "@tiptap/extension-link": "^3.24.0",
    "@tiptap/extension-placeholder": "^3.24.0",
    "@tiptap/extension-table": "^3.24.0",
    "@tiptap/extension-table-cell": "^3.24.0",
    "@tiptap/extension-table-header": "^3.24.0",
    "@tiptap/extension-table-row": "^3.24.0",
    "@tiptap/extension-text-align": "^3.24.0",
    "@tiptap/extension-underline": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/web-push": "^3.6.4",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.4",
    "sharp": "0.34.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "supabase": "^2.98.0",
    "tailwindcss": "^4",
    "tsx": "4.23.0",
    "typescript": "^5"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.10"
  }
}
